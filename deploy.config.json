{
  "version": "1.0.0",
  "appName": "SaveTik Downloader",
  "projectType": "vite-react-spa",
  "environments": {
    "production": {
      "url": "https://savetik-downloader.web.app",
      "branch": "main"
    },
    "staging": {
      "url": "https://savetik-downloader-staging.web.app",
      "branch": "develop"
    }
  },
  "profiles": {
    "vercel": {
      "framework": "vite",
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "cleanUrls": true,
      "rewrites": [
        {
          "source": "/(.*)",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "/assets/(.*)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        }
      ]
    },
    "netlify": {
      "buildCommand": "npm run build",
      "publishDirectory": "dist",
      "redirects": [
        {
          "from": "/*",
          "to": "/index.html",
          "status": 200
        }
      ],
      "headers": {
        "/*": {
          "X-Frame-Options": "DENY",
          "X-XSS-Protection": "1; mode=block",
          "X-Content-Type-Options": "nosniff",
          "Referrer-Policy": "strict-origin-when-cross-origin"
        },
        "/assets/*": {
          "Cache-Control": "public, max-age=31536000, immutable"
        }
      }
    },
    "firebase": {
      "hosting": {
        "public": "dist",
        "ignore": [
          "firebase.json",
          "**/.*",
          "**/node_modules/**"
        ],
        "rewrites": [
          {
            "source": "**",
            "destination": "/index.html"
          }
        ],
        "headers": [
          {
            "source": "/assets/**",
            "headers": [
              {
                "key": "Cache-Control",
                "value": "max-age=31536000"
              }
            ]
          }
        ]
      }
    }
  }
}
