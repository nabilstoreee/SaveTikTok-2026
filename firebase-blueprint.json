{
  "entities": {
    "BrandAd": {
      "title": "BrandAd",
      "description": "Video ad displayed inside the video player",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "desc": { "type": "string" },
        "sponsor": { "type": "string" },
        "domain": { "type": "string" },
        "videoUrl": { "type": "string" },
        "ctaText": { "type": "string" },
        "ctaUrl": { "type": "string" },
        "logoEmoji": { "type": "string" },
        "logoBg": { "type": "string" },
        "accentBg": { "type": "string" },
        "accentText": { "type": "string" },
        "duration": { "type": "number" },
        "category": { "type": "string" },
        "rating": { "type": "string" },
        "downloads": { "type": "string" },
        "tagline": { "type": "string" }
      },
      "required": ["id", "title", "sponsor", "videoUrl", "duration"]
    },
    "RegisteredUser": {
      "title": "RegisteredUser",
      "description": "App user account details including points and access status",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "password": { "type": "string" },
        "points": { "type": "number" },
        "premiumUntil": { "type": "number" },
        "ip": { "type": "string" },
        "banned": { "type": "boolean" },
        "bannedUntil": { "type": "number" },
        "banDurationLabel": { "type": "string" },
        "securityQuestion": { "type": "string" },
        "securityAnswer": { "type": "string" },
        "verified": { "type": "boolean" },
        "hasSeenTutorial": { "type": "boolean" },
        "deleted": { "type": "boolean" }
      },
      "required": ["name", "email", "password", "points"]
    },
    "BannedEmail": {
      "title": "BannedEmail",
      "description": "Banned user emails for fraud or abuse prevention",
      "type": "object",
      "properties": {
        "value": { "type": "string" },
        "reason": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["value", "reason"]
    },
    "BannedIp": {
      "title": "BannedIp",
      "description": "Banned user IP addresses for security enforcement",
      "type": "object",
      "properties": {
        "value": { "type": "string" },
        "reason": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["value", "reason"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "Logs of user logins",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "username": { "type": "string" },
        "points": { "type": "number" },
        "loginTime": { "type": "string" }
      },
      "required": ["email", "username", "points", "loginTime"]
    },
    "PaymentRequest": {
      "title": "PaymentRequest",
      "description": "User subscription payment verification request and chat logs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "planId": { "type": "string" },
        "planLabel": { "type": "string" },
        "planDays": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "status": { "type": "string" },
        "proofImage": { "type": "string" },
        "createdAt": { "type": "string" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "sender": { "type": "string" },
              "text": { "type": "string" },
              "image": { "type": "string" },
              "timestamp": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "userEmail", "status"]
    }
  },
  "firestore": {
    "custom_ads/{adId}": {
      "schema": "BrandAd",
      "description": "Collection of custom video ads"
    },
    "registered_users/{email}": {
      "schema": "RegisteredUser",
      "description": "Collection of registered user accounts"
    },
    "banned_emails/{email}": {
      "schema": "BannedEmail",
      "description": "Collection of banned email addresses"
    },
    "banned_ips/{ip}": {
      "schema": "BannedIp",
      "description": "Collection of banned IP addresses"
    },
    "savetik_activity_logs/{logId}": {
      "schema": "ActivityLog",
      "description": "Collection of user login activity logs"
    },
    "savetik_payment_requests/{requestId}": {
      "schema": "PaymentRequest",
      "description": "Collection of payment requests and support chat history"
    }
  }
}
